# =====================================================
# Mangalam Foods — Environment Variables
# Copy this file to `.env` and fill in your own values.
# Never commit the real `.env` file to git.
# =====================================================

# MongoDB connection string. Use a local Mongo, MongoDB Atlas, or any
# Mongo-compatible URI. Database name is read from DB_NAME below.
MONGO_URL=mongodb://localhost:27017

# Name of the MongoDB database the app should use
DB_NAME=mangalam_foods

# The public URL of the deployed site. Used by metadata + share links.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# CORS origins for the API routes. Use "*" for development.
CORS_ORIGINS=*
